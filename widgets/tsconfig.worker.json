{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "types": [],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/worker",
    "src/protocol.ts",
    "src/backpressure.ts",
    "src/capabilities.ts",
    "src/types.ts",
    "src/eventTypes.ts"
  ]
}

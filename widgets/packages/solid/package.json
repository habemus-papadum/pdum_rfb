{
  "name": "@habemus-papadum/rfb-solid",
  "version": "0.1.0-alpha",
  "description": "SolidJS primitive + component for the pdum.rfb remote framebuffer client.",
  "type": "module",
  "license": "MIT",
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build && node -e \"require('fs').copyFileSync('../rfb-ui/src/rfb.css','dist/styles.css')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@habemus-papadum/rfb-widgets": "workspace:^",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@habemus-papadum/rfb-widgets": "workspace:*",
    "@habemus-papadum/rfb-ui": "workspace:*",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/dom": "^10.4.0",
    "happy-dom": "^15.7.0",
    "solid-js": "^1.9.3",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  }
}

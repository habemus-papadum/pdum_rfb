{
  "name": "@habemus-papadum/rfb-react",
  "version": "0.1.0-alpha",
  "description": "React hook + component for the pdum.rfb remote framebuffer client.",
  "type": "module",
  "license": "MIT",
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build && node -e \"require('fs').copyFileSync('../rfb-ui/src/rfb.css','dist/styles.css')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@habemus-papadum/rfb-widgets": "workspace:^",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@habemus-papadum/rfb-widgets": "workspace:*",
    "@habemus-papadum/rfb-ui": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "happy-dom": "^15.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}

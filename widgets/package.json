{
  "name": "@habemus-papadum/rfb-widgets",
  "version": "0.1.0-alpha",
  "description": "Framework-agnostic remote framebuffer browser client (Web Worker decoding).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "demo:build": "vite build --config vite.demo.config.ts",
    "demo:preview": "vite preview --config vite.demo.config.ts",
    "build:anywidget": "vite build --config vite.anywidget.config.ts && node -e \"require('fs').copyFileSync('packages/rfb-ui/src/rfb.css','../src/pdum/rfb/static/widget.css')\"",
    "build:demo": "pnpm --filter @habemus-papadum/rfb-demo-app build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json && tsc --noEmit -p tsconfig.anywidget.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:demo": "playwright test --config playwright.demo.config.ts",
    "gen:fixtures": "cd .. && uv run python -m pdum.rfb.testing widgets/tests/fixtures/protocol"
  },
  "devDependencies": {
    "@habemus-papadum/rfb-ui": "workspace:*",
    "@playwright/test": "^1.48.0",
    "@vitest/coverage-v8": "^3.0.0",
    "happy-dom": "^15.7.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.0"
  }
}
